/* --- MARCAR FIPE BAIXA (VERSÃO INTEGRADA AO MENU) --- */
function marcarFipeBaixa() {
  try {
    // 1. Usa a função de intervalo que você já tem no menu
    var intervalo = pedirIntervaloLinhas("📉 Marcar Fipe Baixa");
    if (!intervalo) return;
    
    // 2. Autenticação padrão do seu sistema
    var tokenSessao = autenticarSGA();
    if (!tokenSessao) return;

    var ss = SpreadsheetApp.getActiveSpreadsheet();
    var abaAtiva = ss.getActiveSheet();
    var dados = abaAtiva.getDataRange().getValues();
    
    // 3. Define o intervalo de linhas baseado no prompt
    var i_inicio = CONFIG.LINHAS_CABECHALHO; 
    var i_fim = dados.length - 1;
    
    if (intervalo.inicio !== -1) {
      i_inicio = Math.max(intervalo.inicio - 1, CONFIG.LINHAS_CABECHALHO);
      i_fim = Math.min(intervalo.fim - 1, dados.length - 1);
    }
    
    var contMarcados = 0;
    var contErrosApi = 0;
    var codigosMoto = ["3", "126", "115", "100", "105", "127", "116", "32", "33", "34", "35", "95", "96", "97"];

    // 4. Início da Varredura
    for (var i = i_inicio; i <= i_fim; i++) {
      var placa = dados[i][CONFIG.COL_PLACA] ? dados[i][CONFIG.COL_PLACA].toString().trim().toUpperCase() : "";
      var chassi = dados[i][CONFIG.COL_CHASSI] ? dados[i][CONFIG.COL_CHASSI].toString().trim().toUpperCase() : "";
      
      // Prioriza Chassi, se não houver, usa Placa
      var valorBusca = chassi !== "" ? chassi : placa;
      var parametroBusca = chassi !== "" ? "chassi" : "placa";

      if (!valorBusca) continue; 

      var urlConsulta = SGA_CONFIG.URL_CONSULTA_BASE + encodeURIComponent(valorBusca) + "/" + parametroBusca;
      
      try {
        var responseHttp = UrlFetchApp.fetch(urlConsulta, { 
          "method": "get", 
          "headers": { "Authorization": "Bearer " + tokenSessao }, 
          "muteHttpExceptions": true 
        });

        if (responseHttp.getResponseCode() == 200) {
          var json = JSON.parse(responseHttp.getContentText());
          // Hinova pode retornar objeto direto ou array com um objeto dentro
          var veiculo = Array.isArray(json) ? json[0] : json;
          
          if (veiculo && veiculo.codigo_tipo_veiculo != null) {
            var tipoVeiculo = veiculo.codigo_tipo_veiculo.toString();
            var valorFipeRaw = veiculo.valor_fipe;
            var valorFipeNum = 0;
            
            // Tratamento robusto de conversão de moeda (Ex: "35.000,00" -> 35000.0)
            if (valorFipeRaw) {
              var strFipe = valorFipeRaw.toString().trim();
              // Limpa pontos de milhar e troca vírgula por ponto
              strFipe = strFipe.replace(/\./g, '').replace(',', '.');
              // Remove qualquer caractere que não seja número ou ponto
              strFipe = strFipe.replace(/[^\d.]/g, '');
              valorFipeNum = parseFloat(strFipe) || 0;
            }
            
            var isMoto = codigosMoto.indexOf(tipoVeiculo) > -1;
            var isBaixa = false;
            
            // Regra de Negócio: Moto < 20k | Carro < 30k
            if (valorFipeNum > 0) {
              if (isMoto && valorFipeNum < 20000) isBaixa = true;
              else if (!isMoto && valorFipeNum < 30000) isBaixa = true;
            }
            
            // Grava o resultado na coluna definida no CONFIG (Coluna 26 = AA)
            abaAtiva.getRange(i + 1, CONFIG.COL_FIPE_BAIXA + 1).setValue(isBaixa);
            if (isBaixa) contMarcados++;
            
          }
        } else {
          contErrosApi++;
        }
      } catch(errChamada) { 
        contErrosApi++; 
      }
      
      // Pequena pausa para não sobrecarregar a API
      Utilities.sleep(150);
    }
    
    // Atualiza a planilha de uma vez só ao final (mais rápido)
    SpreadsheetApp.flush(); 
    Browser.msgBox("📊 Varredura de Fipe Baixa concluída!\n\n✅ " + contMarcados + " veículos marcados.\n⚠️ Falhas de consulta: " + contErrosApi);
    
  } catch (erroGeral) {
    Browser.msgBox("❌ Erro ao processar Fipe Baixa:\n" + erroGeral.message);
  }
}
