function calcularDiasUteis(dataInicialStr, dataFinal) {
  if (!dataInicialStr) return 0;
  var d = null;
  
  if (dataInicialStr instanceof Date) {
    d = new Date(dataInicialStr.getTime());
  } else {
    var stringData = dataInicialStr.toString();
    if (stringData.indexOf("/") > -1) {
      var partes = stringData.split(" ").split("/");
      d = new Date(partes, partes - 1, partes);
    } else {
      d = new Date(dataInicialStr);
    }
  }
  
  if (isNaN(d.getTime())) return 0;
  
  var dataHoje = new Date(dataFinal.getTime());
  dataHoje.setHours(0, 0, 0, 0);
  d.setHours(0, 0, 0, 0);
  
  var diasUteis = 0;
  var dataAtual = new Date(d.getTime());
  dataAtual.setDate(dataAtual.getDate() + 1);
  
  while (dataAtual <= dataHoje) {
    var diaSemana = dataAtual.getDay();
    if (diaSemana !== 0 && diaSemana !== 6 && !ehFeriadoBrasileiro(dataAtual)) {
      diasUteis++;
    }
    dataAtual.setDate(dataAtual.getDate() + 1);
  }
  return diasUteis;
}

function ehFeriadoBrasileiro(data) {
  var ano = data.getFullYear();
  var mes = data.getMonth();
  var dia = data.getDate();
  
  var feriadosFixos = [
    "1/0",   // 01 de Janeiro
    "21/3",  // 21 de Abril
    "23/3",  // 23 de Abril
    "1/4",   // 01 de Maio
    "24/5",  // 24 de Junho
    "7/8",   // 07 de Setembro
    "12/9",  // 12 de Outubro
    "2/10",  // 02 de Novembro
    "15/10", // 15 de Novembro
    "20/10", // 20 de Novembro
    "25/11"  // 25 de Dezembro
  ];
  
  var chaveData = dia + "/" + mes;
  
  if (feriadosFixos.indexOf(chaveData) > -1) {
    return true;
  }
  
  var a = ano % 19;
  var b = Math.floor(ano / 100);
  var c = ano % 100;
  var d = Math.floor(b / 4);
  var e = b % 4;
  var f = Math.floor((b + 8) / 25);
  var g = Math.floor((b - f + 1) / 3);
  var h = (19 * a + b - d - g + 15) % 30;
  var i = Math.floor(c / 4);
  var k = c % 4;
  var l = (32 + 2 * e + 2 * i - h - k) % 7;
  var m = Math.floor((a + 11 * h + 22 * l) / 451);
  var mesPascoa = Math.floor((h + l - 7 * m + 114) / 31) - 1;
  var diaPascoa = ((h + l - 7 * m + 114) % 31) + 1;
  
  var pascoa = new Date(ano, mesPascoa, diaPascoa);
  var sextaSanta = new Date(pascoa.getTime());
  
  sextaSanta.setDate(pascoa.getDate() - 2);
  
  if (sextaSanta.getDate() === dia && sextaSanta.getMonth() === mes) {
    return true;
  }
  
  var carnaval = new Date(pascoa.getTime());
  carnaval.setDate(pascoa.getDate() - 47);
  
  if (carnaval.getDate() === dia && carnaval.getMonth() === mes) {
    return true;
  }
  
  var corpusChristi = new Date(pascoa.getTime());
  corpusChristi.setDate(pascoa.getDate() + 60);
  
  if (corpusChristi.getDate() === dia && corpusChristi.getMonth() === mes) {
    return true;
  }
  
  return false;
}
