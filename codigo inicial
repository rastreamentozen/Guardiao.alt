/* --- Buscardadosguardião --- */
function buscarDadosGuardiao() {
  var intervalo = pedirIntervaloLinhas("📱 Buscar IMEI (Guardião + Ativos)");
  if (!intervalo) {
    return;
  }
  
  var ss = SpreadsheetApp.getActiveSpreadsheet();
  var abaDestino = ss.getSheetByName(CONFIG.NOME_ABA_PRINCIPAL);
  var abaOrigem = ss.getSheetByName("exportacao_guardiao");
  var abaAtivos = ss.getSheetByName("ativos");
  
  if (!abaDestino) {
    return Browser.msgBox("❌ Aba principal não encontrada!");
  }
  
  var ultimaLinhaDestino = Math.max(abaDestino.getLastRow(), 2);
  var dadosDestino = abaDestino.getRange(1, 1, ultimaLinhaDestino, CONFIG.QTD_COLUNAS).getValues();
  
  function formatarDado(valor) {
    if (!valor) return "Não informado";
    if (valor instanceof Date) return Utilities.formatDate(valor, Session.getScriptTimeZone(), "dd/MM/yyyy");
    return valor.toString().trim() || "Não informado";
  }
  
  var mapaGuardiao = {};
  var mapaAtivos = {};
  
  /* --- 1. LENDO A ABA GUARDIÃO --- */
  if (abaOrigem) {
    var dadosOrigem = abaOrigem.getDataRange().getValues();
    
    // Mapeamento das colunas do Guardião (D=3, G=6, R=17, S=18, U=20)
    var COL_PLACA_GD = 3; // Coluna D
    var COL_IMEI_GD = 6;  // Coluna G
    var COL_GD2_GD = 17;  // Coluna R
    var COL_GD3_GD = 18;  // Coluna S
    var COL_DATA_GD = 20; // Coluna U

    for (var i = 1; i < dadosOrigem.length; i++) {
      var placaGD = dadosOrigem[i][COL_PLACA_GD] ? dadosOrigem[i][COL_PLACA_GD].toString().trim().toUpperCase() : "";
      if (placaGD) {
        var imei = formatarDado(dadosOrigem[i][COL_IMEI_GD]);
        var r = formatarDado(dadosOrigem[i][COL_GD2_GD]);
        var s = formatarDado(dadosOrigem[i][COL_GD3_GD]);
        var u = formatarDado(dadosOrigem[i][COL_DATA_GD]);
        
        if (imei !== "Não informado" || r !== "Não informado" || s !== "Não informado") {
          if (!mapaGuardiao[placaGD]) {
            mapaGuardiao[placaGD] = [];
          }
          mapaGuardiao[placaGD].push({ colG: imei, colR: r, colS: s, colU: u });
        }
      }
    }
  }
  
  /* --- 2. LENDO A ABA ATIVOS --- */
  if (abaAtivos) {
    var dadosAtivos = abaAtivos.getDataRange().getValues();
    
    // Mapeamento das colunas fixas dos Ativos (D=3, E=4, AB=27, AL=37)
    var colPlacaAtivos = 3;  // Coluna D
    var colChassiAtivos = 4; // Coluna E
    var COL_IMEI_ATV = 27;   // Coluna AB
    var COL_DATA_ATV = 37;   // Coluna AL
    
    for (var i = 1; i < dadosAtivos.length; i++) {
      var placaAtv = dadosAtivos[i][colPlacaAtivos] ? dadosAtivos[i][colPlacaAtivos].toString().trim().toUpperCase() : "";
      var chassiAtv = dadosAtivos[i][colChassiAtivos] ? dadosAtivos[i][colChassiAtivos].toString().trim().toUpperCase() : "";
      
      var imeiAtivos = formatarDado(dadosAtivos[i][COL_IMEI_ATV]);
      var dataAtivos = formatarDado(dadosAtivos[i][COL_DATA_ATV]);
      
      if (imeiAtivos !== "Não informado") {
        var registroAtv = { colG: imeiAtivos, colR: "Não informado", colS: "Não informado", colU: dataAtivos };
        if (placaAtv) {
          if (!mapaAtivos[placaAtv]) {
            mapaAtivos[placaAtv] = [];
          }
          mapaAtivos[placaAtv].push(registroAtv);
        }
        if (chassiAtv && chassiAtv !== placaAtv) {
          if (!mapaAtivos[chassiAtv]) {
            mapaAtivos[chassiAtv] = [];
          }
          mapaAtivos[chassiAtv].push(registroAtv);
        }
      }
    }
  }
  
  /* --- 3. CRUZANDO E PREENCHENDO A ABA DE VERIFICAÇÃO --- */
  var contagemPagina1 = {};
  for (var j = CONFIG.LINHAS_CABECHALHO; j < dadosDestino.length; j++) {
    var id = (dadosDestino[j][CONFIG.COL_PLACA] || dadosDestino[j][CONFIG.COL_CHASSI] || "").toString().trim().toUpperCase();
    if (id) {
      contagemPagina1[id] = (contagemPagina1[id] || 0) + 1;
    }
  }
  
  var i_inicio = CONFIG.LINHAS_CABECHALHO;
  var i_fim = dadosDestino.length - 1;
  if (intervalo.inicio !== -1) {
    i_inicio = Math.max(intervalo.inicio - 1, CONFIG.LINHAS_CABECHALHO);
    i_fim = Math.min(intervalo.fim - 1, dadosDestino.length - 1);
  }
  
  var contAtualizados = 0;
  var houveAlteracao = false;
  var usoSequencial = {};
  
  for (var j = i_inicio; j <= i_fim; j++) {
    var p = dadosDestino[j][CONFIG.COL_PLACA] ? dadosDestino[j][CONFIG.COL_PLACA].toString().trim().toUpperCase() : "";
    var c = dadosDestino[j][CONFIG.COL_CHASSI] ? dadosDestino[j][CONFIG.COL_CHASSI].toString().trim().toUpperCase() : "";
    var idBusca = p || c;
    
    if (idBusca) {
      var recsGD = (p && mapaGuardiao[p]) ? mapaGuardiao[p] : ((c && mapaGuardiao[c]) ? mapaGuardiao[c] : []);
      var recsAT = (p && mapaAtivos[p]) ? mapaAtivos[p] : ((c && mapaAtivos[c]) ? mapaAtivos[c] : []);
      var registros = [];
      var imeiSet = {};
      
      for(var r = 0; r < recsGD.length; r++) {
        registros.push(recsGD[r]);
        imeiSet[recsGD[r].colG] = true;
      }
      
      for(var r = 0; r < recsAT.length; r++) {
        if(!imeiSet[recsAT[r].colG]) {
          registros.push(recsAT[r]);
          imeiSet[recsAT[r].colG] = true;
        }
      }

      if (registros.length > 0) {
        if (contagemPagina1[idBusca] === 1) {
          dadosDestino[j][CONFIG.COL_DATA_ENTRADA] = registros.map(function(r){ return r.colU; }).join("\n");
          dadosDestino[j][CONFIG.COL_GUARDAO_1] = registros.map(function(r){ return r.colG; }).join("\n");
          dadosDestino[j][CONFIG.COL_GUARDAO_2] = registros.map(function(r){ return r.colR; }).join("\n");
          dadosDestino[j][CONFIG.COL_GUARDAO_3] = registros.map(function(r){ return r.colS; }).join("\n");
        } else {
          var indice = usoSequencial[idBusca] || 0;
          if (indice < registros.length) {
            dadosDestino[j][CONFIG.COL_DATA_ENTRADA] = registros[indice].colU;
            dadosDestino[j][CONFIG.COL_GUARDAO_1] = registros[indice].colG;
            dadosDestino[j][CONFIG.COL_GUARDAO_2] = registros[indice].colR;
            dadosDestino[j][CONFIG.COL_GUARDAO_3] = registros[indice].colS;
            usoSequencial[idBusca] = indice + 1;
          }
        }
        houveAlteracao = true;
        contAtualizados++;
      }
    }
  }
  
  if (houveAlteracao) {
    abaDestino.getRange(2, 1, dadosDestino.length - 1, CONFIG.QTD_COLUNAS).setValues(dadosDestino.slice(1));
    SpreadsheetApp.flush();
    Browser.msgBox("✅ Sincronização Concluída!\n" + contAtualizados + " veículos atualizados com os dados de Guardião/Ativos.");
  } else {
    Browser.msgBox("⚠️ Nenhum dado novo encontrado para atualizar.");
  }
}
