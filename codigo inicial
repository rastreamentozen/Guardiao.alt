/* --- 🚦 Classificar Envios (Ativos/Inativos) --- */
function classificarEnviosPorStatusSGA() {
  var ss = SpreadsheetApp.getActiveSpreadsheet();
  var aba = ss.getActiveSheet();
  var ultimaLinha = aba.getLastRow();

  // Se a planilha só tiver cabeçalho, encerra
  if (ultimaLinha <= CONFIG.LINHAS_CABECHALHO) return;

  var range = aba.getRange(1, 1, ultimaLinha, CONFIG.QTD_COLUNAS);
  var dados = range.getValues();
  var houveAlteracao = false;
  var contClassificados = 0;

  for (var i = CONFIG.LINHAS_CABECHALHO; i < dados.length; i++) {
    // Pegando os valores das colunas e padronizando os textos (minúsculas/maiúsculas)
    var statusEnvio = dados[i][CONFIG.COL_ENVIAR] ? dados[i][CONFIG.COL_ENVIAR].toString().trim().toLowerCase() : "";
    var classificacao = dados[i][CONFIG.COL_CLASSIFICACAO] ? dados[i][CONFIG.COL_CLASSIFICACAO].toString().trim().toLowerCase() : "";
    var situacao = dados[i][CONFIG.COL_SITUACAO] ? dados[i][CONFIG.COL_SITUACAO].toString().trim().toUpperCase() : "";

    // 1. Pular a verificação se já estiver com status definitivo
    if (statusEnvio === "enviar" || statusEnvio === "não enviar" || statusEnvio === "nao enviar" || statusEnvio === "enviado") {
      continue;
    }

    // 2. Se a Classificação for DIFERENTE de "Concluido", marca para "Verificar"
    if (classificacao !== "concluído" && classificacao !== "concluido") {
       dados[i][CONFIG.COL_ENVIAR] = "Verificar"; // Idêntico à validação
       houveAlteracao = true;
       contClassificados++;
       continue; // Pula para a próxima linha
    }

    // 3. Se a Classificação for "Concluido", analisa a coluna "Situação"
    if (situacao === "ATIVO") {
      dados[i][CONFIG.COL_ENVIAR] = "enviar"; // <-- CORRIGIDO AQUI (e minúsculo)
      houveAlteracao = true;
      contClassificados++;
    } else {
      // Qualquer situação que não seja "ATIVO" (ex: Inativo, Pendente)
      dados[i][CONFIG.COL_ENVIAR] = "Não enviar"; // Idêntico à validação
      houveAlteracao = true;
      contClassificados++;
    }
  }

  // Salva todas as alterações na planilha de uma só vez
  if (houveAlteracao) {
    range.setValues(dados);
    SpreadsheetApp.flush();
    Browser.msgBox("🚦 Classificação Concluída!\\n\\n" + contClassificados + " linhas atualizadas com sucesso.");
  } else {
    Browser.msgBox("🚦 Nenhuma linha precisava ser classificada no momento.");
  }
}
/* --- 🛡️ FUNÇÃO DE INTERVALO SUPER BLINDADA (PESCADOR DE NÚMEROS) --- */
function pedirIntervaloLinhas(nomeAcao) {
  var ui = SpreadsheetApp.getUi();
  var response = ui.prompt(
    nomeAcao,
    "Deixe em branco para varrer TODAS as pendências da aba.\nOu digite as linhas (Ex: 208-220):",
    ui.ButtonSet.OK_CANCEL
  );
  
  if (response.getSelectedButton() !== ui.Button.OK) {
    return null;
  }
  
  var input = response.getResponseText().trim();
  
  if (input === "") {
    return { inicio: -1, fim: -1 };
  }
  
  var numeros = input.match(/\d+/g);
  
  if (numeros && numeros.length >= 2) {
    return {
      inicio: parseInt(numeros, 10),
      fim: parseInt(numeros, 10)
    };
  } else if (numeros && numeros.length === 1) {
    return {
      inicio: parseInt(numeros, 10),
      fim: parseInt(numeros, 10)
    };
  } else {
    Browser.msgBox("❌ Formato não reconhecido!\n\nVocê digitou: '" + input + "'\nTente digitar apenas os números. Exemplo: 208-220");
    return null;
  }
}

/**
 * 📝 SINCRONIZAR NOTAS OCULTAS (ISOLAMENTO ESTRITO POR LINHA - V3)
 * Uso de let/const para garantir que os dados não vazem entre clientes.
 */
function sincronizarComentariosOcultos() {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const aba = ss.getActiveSheet();
  const ultimaLinha = aba.getLastRow();
  
  if (ultimaLinha < 2) {
    return Browser.msgBox("⚠️ A planilha não tem dados suficientes.");
  }

  const rangeTotal = aba.getRange(1, 1, ultimaLinha, 27);
  const dados = rangeTotal.getValues();
  
  // 🛡️ Nomes atualizados conforme seu pedido
  const nomesDasColunas = {
    1: "Data de Entrada",
    5: "Fipe Alta",
    6: "Email",
    8: "Bairro",
    9: "Cidade",
    10: "Estado",
    12: "Situação",
    15: "Guardião 2",
    16: "Guardião 3",
    20: "Data Email",
    21: "Data Whats",
    22: "Responsável Email",
    23: "Responsável Whats",
    25: "Trava Estado",
    26: "Fipe Baixa"
  };
  
  const colunasOcultasTexto = "1, 5, 6, 8, 9, 10, 12, 15, 16, 20, 21, 22, 23, 25, 26";
  const colunasOcultas = colunasOcultasTexto.split(",").map(function(num) {
    return parseInt(num.trim(), 10);
  });

  const matrizDeNotas = [];

  for (let i = 0; i < dados.length; i++) {
    if (i === 0) {
      matrizDeNotas.push([""]);
      continue;
    }

    const linhaAtual = dados[i];
    let textoDaNota = "";
    let temInformacaoValida = false;

    for (let c = 0; c < colunasOcultas.length; c++) {
      const idxColuna = colunasOcultas[c];
      const valorDaCelula = linhaAtual[idxColuna];
      
      const nomeDaColuna = nomesDasColunas[idxColuna] || ("Coluna " + idxColuna);

      if (valorDaCelula !== "" && valorDaCelula !== null && valorDaCelula !== undefined) {
        let valorFormatado = valorDaCelula;

        // 1. Formatação de data
        if (valorDaCelula instanceof Date) {
          valorFormatado = Utilities.formatDate(valorDaCelula, Session.getScriptTimeZone(), "dd/MM/yyyy");
        } 
        // 2. Trava para Checkboxes (True/False viram Sim/Não em vez de 1 e 0)
        else if (typeof valorDaCelula === "boolean") {
          valorFormatado = valorDaCelula ? "Sim" : "Não";
        }
        // 3. Formatação de Moeda APENAS se for um número de verdade
        else if ((idxColuna === 5 || idxColuna === 26) && typeof valorDaCelula === "number") {
          valorFormatado = "R$ " + Number(valorDaCelula).toLocaleString('pt-BR', {minimumFractionDigits: 2});
        }

        textoDaNota += "📌 " + nomeDaColuna + ": " + valorFormatado + "\n";
        temInformacaoValida = true;
      }
    }

    matrizDeNotas.push([temInformacaoValida ? textoDaNota.trim() : ""]);
  }

  try {
    const rangeNotas = aba.getRange(1, 4, ultimaLinha, 1);
    rangeNotas.clearNote(); 
    rangeNotas.setNotes(matrizDeNotas); 
    
    SpreadsheetApp.flush();
    Browser.msgBox("✅ Tudo pronto! Comentários 100% formatados e sincronizados.");
  } catch (e) {
    Browser.msgBox("❌ Erro ao gravar notas: " + e.message);
  }
}
/* --- INTEGRAÇÃO PRINCIPAL HINOVA (MECÂNICA ANTIGA RESTAURADA) --- */
function processarVeiculosSGA() {
  var tokenSessao = autenticarSGA();
  if (!tokenSessao) {
    Browser.msgBox("❌ Falha na autenticação SGA Hinova.");
    return;
  }
  var ss = SpreadsheetApp.getActiveSpreadsheet();
  var planilha = ss.getActiveSheet();
  var ultimaLinha = planilha.getLastRow();
  if (ultimaLinha <= CONFIG.LINHAS_CABECHALHO) return; 
  
  var range = planilha.getRange(1, 1, ultimaLinha, CONFIG.QTD_COLUNAS);
  var dados = range.getValues();
  var houveAlteracao = false;
  var contProcessados = 0;
  
  for (var i = CONFIG.LINHAS_CABECHALHO; i < dados.length; i++) {
    var acaoAPI = dados[i][CONFIG.COL_ACAO_API] ? dados[i][CONFIG.COL_ACAO_API].toString().trim().toLowerCase() : "";
    if (acaoAPI !== "verificar") continue; 
    
    var placa = dados[i][CONFIG.COL_PLACA] ? dados[i][CONFIG.COL_PLACA].toString().trim().toUpperCase() : "";
    var chassi = dados[i][CONFIG.COL_CHASSI] ? dados[i][CONFIG.COL_CHASSI].toString().trim().toUpperCase() : "";
    var valorBusca = placa || chassi;
    var parametroBusca = placa ? "placa" : "chassi";
    
    if (!valorBusca) {
      dados[i][CONFIG.COL_ACAO_API] = "Falta Placa/Chassi";
      houveAlteracao = true;
      continue;
    }
    
    var endpoint = SGA_CONFIG.URL_CONSULTA_BASE + encodeURIComponent(valorBusca) + "/" + parametroBusca;
    try {
      var resposta = UrlFetchApp.fetch(endpoint, {
        "method": "GET",
        "headers": { "Authorization": "Bearer " + tokenSessao },
        "muteHttpExceptions": true 
      });
      
      if (resposta.getResponseCode() == 200) {
        var retorno = JSON.parse(resposta.getContentText());
        var v = Array.isArray(retorno) ? retorno[0] : retorno;
        
        if (v && v.codigo_veiculo) {
          var dataEntradaCrua = v.data_cadastro || v.data_contrato || v.data_cadastro_associado || v.data_contrato_associado || v.data_inicio_contrato_veiculo || v.data_inicio_contrato_associado || v.data_cadastro_veiculo || v.data_criacao || "";
          if (!dados[i][CONFIG.COL_DATA_ENTRADA] && dataEntradaCrua) {
             var stringData = dataEntradaCrua.toString().trim().split(" ")[0]; 
             if (stringData.indexOf("-") > -1) { 
                 var partesData = stringData.split("-");
                 if (partesData.length === 3) dados[i][CONFIG.COL_DATA_ENTRADA] = partesData[2] + "/" + partesData[1] + "/" + partesData[0];
             } else { 
                 dados[i][CONFIG.COL_DATA_ENTRADA] = stringData;
             }
          }
          
          if (!dados[i][CONFIG.COL_NOME]) dados[i][CONFIG.COL_NOME] = (v.nome || v.nome_associado || "").toString().trim();
          if (!dados[i][CONFIG.COL_PLACA]) dados[i][CONFIG.COL_PLACA] = (v.placa || "").toString().trim().toUpperCase();
          if (!dados[i][CONFIG.COL_CHASSI]) dados[i][CONFIG.COL_CHASSI] = (v.chassi || "").toString().trim().toUpperCase();
          if (v.valor_fipe) dados[i][CONFIG.COL_FIPE] = parseFloat(v.valor_fipe.toString().replace(",", ".")); 
          
          var codClass = v.codigo_classificacao ? v.codigo_classificacao.toString() : "";
          dados[i][CONFIG.COL_CLASSIFICACAO] = MAPA_CLASSIFICACAO[codClass] || "Código " + codClass;

          if (!dados[i][CONFIG.COL_EMAIL]) dados[i][CONFIG.COL_EMAIL] = (v.email || "").toString().trim().toLowerCase();
          if (!dados[i][CONFIG.COL_TELEFONE]) {
            var fone = (v.ddd_celular ? "(" + v.ddd_celular + ") " : "") + (v.telefone_celular || v.telefone || "");
            dados[i][CONFIG.COL_TELEFONE] = fone.trim();
          }
          
          if (!dados[i][CONFIG.COL_BAIRRO]) dados[i][CONFIG.COL_BAIRRO] = (v.bairro || "").toString().trim();
          if (!dados[i][CONFIG.COL_CIDADE]) dados[i][CONFIG.COL_CIDADE] = (v.cidade || "").toString().trim();
          if (!dados[i][CONFIG.COL_ESTADO]) dados[i][CONFIG.COL_ESTADO] = (v.estado || "").toString().trim();
          
          var statusRetornado = v.descricao_situacao_veiculo || v.situacao_veiculo || v.descricao_situacao || v.situacao || "";
          if (!statusRetornado) {
            var codSit = v.codigo_situacao_veiculo || v.codigo_situacao;
            if (codSit == 1 || codSit == "1") statusRetornado = "ATIVO";
            else if (codSit == 2 || codSit == "2") statusRetornado = "INATIVO";
            else if (codSit == 3 || codSit == "3") statusRetornado = "PENDENTE";
            else if (codSit) statusRetornado = "Cód: " + codSit;
          }
          dados[i][CONFIG.COL_SITUACAO] = (statusRetornado || "S/ STATUS").toString().trim().toUpperCase();
          dados[i][CONFIG.COL_ACAO_API] = "Concluído";
          
          contProcessados++;
          houveAlteracao = true;
        } else {
          dados[i][CONFIG.COL_ACAO_API] = "Não Encontrado";
          houveAlteracao = true;
        }
      }
    } catch (e) { Logger.log(e.message); }
    Utilities.sleep(200); 
  }
  if (houveAlteracao) {
    range.setValues(dados);
    planilha.getRange(2, CONFIG.COL_FIPE + 1, ultimaLinha - 1, 1).setNumberFormat('R$ #,##0.00');
    SpreadsheetApp.flush(); 
  }
  Browser.msgBox("✅ Verificação Concluída! " + contProcessados + " veículos processados.");
}

/* --- CorrigirZeroKM --- */
function corrigirZeroKmGuardiao() {
  var ss = SpreadsheetApp.getActiveSpreadsheet();
  var abaGuardiao = ss.getSheetByName("exportacao_guardiao");
  var abaAtivos = ss.getSheetByName("ativos");
  
  if (!abaGuardiao || !abaAtivos) {
    return Browser.msgBox("Erro: Abas exportacao_guardiao ou ativos não encontradas!");
  }
  
  var ultimaLinhaAtivos = abaAtivos.getLastRow();
  if(ultimaLinhaAtivos < 1) return;
  var dadosAtivos = abaAtivos.getRange(1, 1, ultimaLinhaAtivos, 40).getValues();
  
  var mapaImeiChassi = new Map();
  
  // 1. Mapeando a aba ativos (sem usar nenhum colchete)
  for (var i = 1; i < dadosAtivos.length; i++) {
    var linhaAtivo = dadosAtivos.slice(i, i + 1).pop();
    
    // Pega a coluna AB (27) e a coluna E (4)
    var imeiAtivos = String(linhaAtivo.slice(27, 28).pop() || "").trim();
    var chassiAtivos = String(linhaAtivo.slice(4, 5).pop() || "").trim().toUpperCase();
    
    if (imeiAtivos !== "" && chassiAtivos !== "") {
      mapaImeiChassi.set(imeiAtivos, chassiAtivos);
    }
  }
  
  var ultimaLinhaGuardiao = abaGuardiao.getLastRow();
  if(ultimaLinhaGuardiao < 1) return;
  var rangeGuardiao = abaGuardiao.getRange(1, 1, ultimaLinhaGuardiao, 20);
  var dadosGuardiao = rangeGuardiao.getValues();
  
  var alterou = false;
  var cont = 0;
  var logFalhas = new Array();
  
  // 2. Varrendo o Guardião
  for (var j = 1; j < dadosGuardiao.length; j++) {
    var linhaGuardiao = dadosGuardiao.slice(j, j + 1).pop();
    
    // Pega a Placa (Coluna D=3) e IMEI (Coluna G=6)
    var placaGuardiao = String(linhaGuardiao.slice(3, 4).pop() || "").trim();
    var imeiGuardiao = String(linhaGuardiao.slice(6, 7).pop() || "").trim();
    
    // REGRA ESTRITA: Exatamente igual a "Zero KM"
    var temZero = (placaGuardiao === "Zero KM");
    
    if (temZero) {
      if (imeiGuardiao !== "" && mapaImeiChassi.has(imeiGuardiao)) {
        // Substitui a Placa pelo Chassi direto na memoria
        linhaGuardiao.splice(3, 1, mapaImeiChassi.get(imeiGuardiao));
        alterou = true;
        cont++;
      } else {
        logFalhas.push(imeiGuardiao);
      }
    }
  }
  
  // 3. Gravando o resultado
  if (alterou) {
    rangeGuardiao.setValues(dadosGuardiao);
    SpreadsheetApp.flush();
    Browser.msgBox("Sucesso! " + cont + " veiculos Zero Km foram atualizados para o Chassi.");
  } else {
    if (logFalhas.length > 0) {
      var primeiroErro = logFalhas.slice(0, 1).pop();
      Browser.msgBox("Aviso: O script achou o Zero KM no Guardiao! Ele leu este IMEI: " + primeiroErro + " ... Porem, não achou o Chassi na aba ativos.");
    } else {
      Browser.msgBox("Aviso: O script nao encontrou o texto exato 'Zero KM' no Guardiao.");
    }
  }
